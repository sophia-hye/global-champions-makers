# Supabase — supabase.com > 프로젝트 > Project Settings > API 에서 복사
# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요. (.env.local 은 git에 커밋되지 않습니다)

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# anon (public) key — 브라우저에서 사용
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role key — 서버 전용(관리자 회원관리). 절대 클라이언트/공개 금지!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 이메일 발송 (Resend) — resend.com 가입 후 API Key 발급
# 발신 도메인 인증 전에는 MAIL_FROM 을 onboarding@resend.dev 로 두고
# 본인 가입 이메일로만 테스트 발송됩니다. 임의 수신자에게 보내려면 도메인 인증 필요.
RESEND_API_KEY=your-resend-api-key
MAIL_FROM=GCM <onboarding@resend.dev>
